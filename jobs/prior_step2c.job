#!/bin/bash
#SBATCH --job-name=prior_step2c
#SBATCH --output=logs/prior_step2c_%j.out
#SBATCH --error=logs/prior_step2c_%j.err
#SBATCH --time=01:00:00
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=4
#SBATCH --mem=32G

set -euo pipefail
source "$HOME/NODIS/snellius_modules.sh"
source "$HOME/NODIS/.venv/bin/activate"
echo "[$(date)] Step 2c: Spearman correlation prior"
python "$HOME/NODIS/methodtotest/build_prior.py" --step 2c
echo "[$(date)] Step 2c done"
