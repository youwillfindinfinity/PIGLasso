#!/bin/bash
#SBATCH --job-name=prior_step3
#SBATCH --output=logs/prior_step3_%j.out
#SBATCH --error=logs/prior_step3_%j.err
#SBATCH --time=00:30:00
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=1
#SBATCH --mem=64G

set -euo pipefail
source "$HOME/NODIS/snellius_modules.sh"
source "$HOME/NODIS/.venv/bin/activate"
echo "[$(date)] Step 3: combine priors"
python "$HOME/NODIS/methodtotest/build_prior.py" --step 3
echo "[$(date)] Step 3 done"
