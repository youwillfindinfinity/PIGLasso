# PIGLasso — Environment configuration template
# Copy to .env and fill in your values:
#   cp .env.template .env
# IMPORTANT: Never commit .env — it is gitignored.

# -----------------------------------------------------------------------
# Snellius HPC (SURF)
# Used by jobs/hpc_sync.sh for rsync transfers
# -----------------------------------------------------------------------
SNELLIUS_HOST=snellius.surf.nl
SNELLIUS_USER=your_username
SNELLIUS_PASSWORD=your_password
SNELLIUS_PORT=22
SNELLIUS_REMOTE_DIR=/home/your_username/PIGLasso

# -----------------------------------------------------------------------
# Snellius module environment — update if cluster software changes
# -----------------------------------------------------------------------
SNELLIUS_MODULE_ENV=2023
SNELLIUS_MODULE_R=R/4.3.2-gfbf-2023a

# -----------------------------------------------------------------------
# SLURM
# -----------------------------------------------------------------------
SNELLIUS_PARTITION=rome

# -----------------------------------------------------------------------
# External APIs
# STRING database (no API key required — uses public REST endpoint)
# Override if STRING changes its base URL
# -----------------------------------------------------------------------
STRING_API_URL=https://string-db.org/api
STRING_SPECIES=9606
